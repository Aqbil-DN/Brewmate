# ============================================================================
# BrewMate AI — .gitignore
# Covers: Node.js, Flutter, Dart, Prisma, environment files, IDE, OS, builds
# ============================================================================

# --------------------------------------------------------------------------
# Environment & Secrets
# --------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.jks

# --------------------------------------------------------------------------
# Node.js / NestJS Backend
# --------------------------------------------------------------------------
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn/
*.tsbuildinfo
coverage/

# --------------------------------------------------------------------------
# Flutter / Dart Mobile
# --------------------------------------------------------------------------
# Dart
.dart_tool/
.packages
pubspec.lock
*.dart.js
*.js_
*.js.deps
*.js.map

# Flutter
.flutter-plugins
.flutter-plugins-dependencies
**/.symlinks/
**/Flutter/ephemeral/
**/Pods/

# Flutter build outputs
mobile/build/
mobile/.dart_tool/

# Generated files
*.g.dart
*.freezed.dart
*.mocks.dart
*.gr.dart

# iOS
mobile/ios/Pods/
mobile/ios/.symlinks/
mobile/ios/Flutter/Flutter.framework
mobile/ios/Flutter/Flutter.podspec
mobile/ios/Flutter/Generated.xcconfig
mobile/ios/Flutter/app.flx
mobile/ios/Flutter/engine/
mobile/ios/ServiceDefinitions.json
mobile/ios/Runner/GeneratedPluginRegistrant.*

# Android
mobile/android/.gradle/
mobile/android/captures/
mobile/android/gradlew
mobile/android/gradlew.bat
mobile/android/local.properties
mobile/android/**/GeneratedPluginRegistrant.java
mobile/android/key.properties
*.apk
*.aab

# --------------------------------------------------------------------------
# Prisma
# --------------------------------------------------------------------------
backend/prisma/migrations/**/migration_lock.toml

# --------------------------------------------------------------------------
# IDE & Editors
# --------------------------------------------------------------------------
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/extensions.json

# IntelliJ / Android Studio
.idea/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/

# Vim / Neovim
*.swp
*.swo
*~
Session.vim

# --------------------------------------------------------------------------
# OS Files
# --------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory

# --------------------------------------------------------------------------
# Build & Misc
# --------------------------------------------------------------------------
*.log
*.tmp
*.temp
*.cache
.eslintcache
.parcel-cache/
.turbo/
.vercel/
.next/
out/
tmp/
temp/
