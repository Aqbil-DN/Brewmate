// Prisma schema for BrewMate AI
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── ENUMS ────────────────────────────────────────────────────────────────────

enum AuthProvider {
  email
  google
  apple

  @@map("auth_provider")
}

enum OrderType {
  dine_in
  takeaway
  pickup

  @@map("order_type")
}

enum ProductStatus {
  active
  inactive
  archived

  @@map("product_status")
}

enum DrinkType {
  coffee
  non_coffee
  both

  @@map("drink_type")
}

enum BudgetTier {
  budget
  regular
  premium

  @@map("budget_tier")
}

enum OrderStatus {
  pending
  confirmed
  preparing
  ready
  completed
  cancelled

  @@map("order_status")
}

enum PaymentStatus {
  unpaid
  pending
  paid
  refunded
  failed
  expired

  @@map("payment_status")
}

enum TagType {
  dietary
  promotional
  label

  @@map("tag_type")
}

enum DiscountType {
  percentage
  fixed_amount
  free_item

  @@map("discount_type")
}

enum InputMode {
  quiz
  chat

  @@map("input_mode")
}

// ── MODELS ───────────────────────────────────────────────────────────────────

model User {
  id           String       @id @default(uuid()) @db.Uuid
  email        String       @unique @db.VarChar(255)
  passwordHash String?      @map("password_hash") @db.VarChar(255)
  fullName     String       @map("full_name") @db.VarChar(100)
  phoneNumber  String?      @unique @map("phone_number") @db.VarChar(20)
  avatarUrl    String?      @map("avatar_url") @db.Text
  authProvider AuthProvider @default(email) @map("auth_provider")
  isVerified   Boolean      @default(false) @map("is_verified")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  userPreferences UserPreference?
  addresses       Address[]
  cart            Cart?
  orders          Order[]
  loyaltyStamps   LoyaltyStamp[]
  aiQuizSessions  AiQuizSession[]

  @@index([phoneNumber])
  @@index([createdAt])
  @@map("users")
}

model UserPreference {
  id                     String     @id @default(uuid()) @db.Uuid
  userId                 String     @unique @map("user_id") @db.Uuid
  allergenTags           String[]   @map("allergen_tags")
  defaultOrderType       OrderType? @map("default_order_type")
  defaultPaymentMethod   String?    @map("default_payment_method") @db.VarChar(50)
  aiNotificationsEnabled Boolean    @default(true) @map("ai_notifications_enabled")
  updatedAt              DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model Address {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  label       String   @db.VarChar(50)
  fullAddress String   @map("full_address") @db.Text
  city        String   @db.VarChar(100)
  lat         Decimal? @db.Decimal(10, 8)
  lng         Decimal? @db.Decimal(11, 8)
  isDefault   Boolean  @default(false) @map("is_default")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

model Category {
  id           String    @id @default(uuid()) @db.Uuid
  name         String    @unique @db.VarChar(100)
  slug         String    @unique @db.VarChar(100)
  iconUrl      String?   @map("icon_url") @db.Text
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")
  products     Product[]

  @@map("categories")
}

model Product {
  id          String        @id @default(uuid()) @db.Uuid
  categoryId  String        @map("category_id") @db.Uuid
  name        String        @db.VarChar(150)
  description String?       @db.Text
  basePrice   Decimal       @map("base_price") @db.Decimal(12, 2)
  imageUrl    String?       @map("image_url") @db.Text
  status      ProductStatus @default(active)
  isAvailable Boolean       @default(true) @map("is_available")
  isFeatured  Boolean       @default(false) @map("is_featured")
  costPrice   Decimal?      @map("cost_price") @db.Decimal(12, 2)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  category               Category                @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  productVariants        ProductVariant[]
  productAiAttributes    ProductAiAttribute?
  productTags            ProductTag[]
  cartItems              CartItem[]
  orderItems             OrderItem[]
  aiRecommendationEvents AiRecommendationEvent[]

  @@index([categoryId])
  @@index([status, isAvailable])
  @@index([isFeatured])
  @@map("products")
}

model ProductVariant {
  id            String  @id @default(uuid()) @db.Uuid
  productId     String  @map("product_id") @db.Uuid
  name          String  @db.VarChar(50)
  priceModifier Decimal @default(0.00) @map("price_modifier") @db.Decimal(10, 2)
  isDefault     Boolean @default(false) @map("is_default")
  isAvailable   Boolean @default(true) @map("is_available")

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([productId, name])
  @@map("product_variants")
}

model ProductAiAttribute {
  id             String     @id @default(uuid()) @db.Uuid
  productId      String     @unique @map("product_id") @db.Uuid
  needTags       String[]   @map("need_tags")
  flavorTags     String[]   @map("flavor_tags")
  drinkType      DrinkType  @map("drink_type")
  budgetTier     BudgetTier @map("budget_tier")
  caffeineLevel  Int        @default(5) @map("caffeine_level") @db.SmallInt
  sweetnessLevel Int        @default(5) @map("sweetness_level") @db.SmallInt
  strengthLevel  Int        @default(5) @map("strength_level") @db.SmallInt
  aiDescription  String?    @map("ai_description") @db.Text

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_ai_attributes")
}

model Tag {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique @db.VarChar(50)
  tagType     TagType      @map("tag_type")
  colorHex    String?      @map("color_hex") @db.VarChar(7)
  productTags ProductTag[]

  @@map("tags")
}

model ProductTag {
  productId String @map("product_id") @db.Uuid
  tagId     String @map("tag_id") @db.Uuid

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@map("product_tags")
}

model Cart {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cartItems CartItem[]

  @@map("carts")
}

model CartItem {
  id                  String   @id @default(uuid()) @db.Uuid
  cartId              String   @map("cart_id") @db.Uuid
  productId           String   @map("product_id") @db.Uuid
  variantId           String?  @map("variant_id") @db.Uuid
  quantity            Int      @db.SmallInt
  unitPrice           Decimal  @map("unit_price") @db.Decimal(12, 2)
  specialInstructions String?  @map("special_instructions") @db.Text
  addedAt             DateTime @default(now()) @map("added_at") @db.Timestamptz

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([cartId, productId, variantId])
  @@map("cart_items")
}

model Order {
  id               String        @id @default(uuid()) @db.Uuid
  userId           String        @map("user_id") @db.Uuid
  addressId        String?       @map("address_id") @db.Uuid
  orderNumber      String        @unique @map("order_number") @db.VarChar(20)
  orderType        OrderType     @map("order_type")
  status           OrderStatus   @default(pending)
  paymentStatus    PaymentStatus @default(unpaid) @map("payment_status")
  paymentMethod    String        @map("payment_method") @db.VarChar(50)
  paymentReference String?       @map("payment_reference") @db.VarChar(100)
  subtotal         Decimal       @db.Decimal(12, 2)
  discountAmount   Decimal       @default(0.00) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount        Decimal       @default(0.00) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount      Decimal       @map("total_amount") @db.Decimal(12, 2)
  promoCode        String?       @map("promo_code") @db.VarChar(50)
  specialNotes     String?       @map("special_notes") @db.Text
  placedAt         DateTime      @default(now()) @map("placed_at") @db.Timestamptz
  completedAt      DateTime?     @map("completed_at") @db.Timestamptz
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  user          User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  address       Address?       @relation(fields: [addressId], references: [id], onDelete: SetNull)
  orderItems    OrderItem[]
  loyaltyStamps LoyaltyStamp[]
  aiQuizSession AiQuizSession?

  @@index([userId, placedAt])
  @@index([status])
  @@index([paymentStatus])
  @@map("orders")
}

model OrderItem {
  id                  String  @id @default(uuid()) @db.Uuid
  orderId             String  @map("order_id") @db.Uuid
  productId           String  @map("product_id") @db.Uuid
  variantId           String? @map("variant_id") @db.Uuid
  productNameSnapshot String  @map("product_name_snapshot") @db.VarChar(150)
  variantNameSnapshot String? @map("variant_name_snapshot") @db.VarChar(50)
  unitPriceSnapshot   Decimal @map("unit_price_snapshot") @db.Decimal(12, 2)
  quantity            Int     @db.SmallInt
  specialInstructions String? @map("special_instructions") @db.Text

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

model Promotion {
  id            String       @id @default(uuid()) @db.Uuid
  code          String       @unique @db.VarChar(50)
  discountType  DiscountType @map("discount_type")
  discountValue Decimal      @map("discount_value") @db.Decimal(10, 2)
  minOrderValue Decimal      @default(0.00) @map("min_order_value") @db.Decimal(12, 2)
  maxUses       Int?         @map("max_uses")
  currentUses   Int          @default(0) @map("current_uses")
  isActive      Boolean      @default(true) @map("is_active")
  validFrom     DateTime     @map("valid_from") @db.Timestamptz
  validUntil    DateTime     @map("valid_until") @db.Timestamptz

  @@map("promotions")
}

model LoyaltyStamp {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  orderId       String?  @map("order_id") @db.Uuid
  stampsEarned  Int      @map("stamps_earned") @db.SmallInt
  stampsBalance Int      @map("stamps_balance")
  earnedAt      DateTime @default(now()) @map("earned_at") @db.Timestamptz

  user  User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  order Order? @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("loyalty_stamps")
}

model AiQuizSession {
  id                         String    @id @default(uuid()) @db.Uuid
  userId                     String?   @map("user_id") @db.Uuid
  inputMode                  InputMode @map("input_mode")
  needAnswer                 String?   @map("need_answer") @db.VarChar(50)
  flavorAnswer               String?   @map("flavor_answer") @db.VarChar(50)
  drinkTypeAnswer            String?   @map("drink_type_answer") @db.VarChar(50)
  budgetAnswer               String?   @map("budget_answer") @db.VarChar(50)
  chatTranscript             Json?     @map("chat_transcript") @db.JsonB
  recommendationsShown       Int       @default(0) @map("recommendations_shown") @db.SmallInt
  recommendationsAddedToCart Int       @default(0) @map("recommendations_added_to_cart") @db.SmallInt
  resultedInOrder            Boolean   @default(false) @map("resulted_in_order")
  resultingOrderId           String?   @unique @map("resulting_order_id") @db.Uuid
  startedAt                  DateTime  @default(now()) @map("started_at") @db.Timestamptz
  completedAt                DateTime? @map("completed_at") @db.Timestamptz

  user            User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  resultingOrder  Order?                  @relation(fields: [resultingOrderId], references: [id], onDelete: SetNull)
  recommendations AiRecommendationEvent[]

  @@map("ai_quiz_sessions")
}

model AiRecommendationEvent {
  id             String   @id @default(uuid()) @db.Uuid
  sessionId      String   @map("session_id") @db.Uuid
  productId      String   @map("product_id") @db.Uuid
  rankPosition   Int      @map("rank_position") @db.SmallInt
  matchScore     Decimal  @map("match_score") @db.Decimal(5, 2)
  wasAddedToCart Boolean  @default(false) @map("was_added_to_cart")
  wasPurchased   Boolean  @default(false) @map("was_purchased")
  aiReasonText   String?  @map("ai_reason_text") @db.Text
  recommendedAt  DateTime @default(now()) @map("recommended_at") @db.Timestamptz

  session AiQuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("ai_recommendation_events")
}
